modules = ["nodejs-24"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/pwv-dashboard: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/pwv-impact: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/pwv-proof: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/pwv-colorado: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/pwv-microsite: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: API Server"

[[workflows.workflow]]
name = "artifacts/pwv-dashboard: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BASE_PATH=/pwv-dashboard/ PORT=23733 pnpm --filter @workspace/pwv-dashboard run dev"
waitForPort = 23733

[[workflows.workflow]]
name = "artifacts/pwv-impact: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BASE_PATH=/impact/ PORT=25854 pnpm --filter @workspace/pwv-impact run dev"
waitForPort = 25854

[[workflows.workflow]]
name = "artifacts/pwv-proof: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BASE_PATH=/results/ PORT=20144 pnpm --filter @workspace/pwv-proof run dev"
waitForPort = 20144

[[workflows.workflow]]
name = "artifacts/pwv-home: web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BASE_PATH=/ PORT=22335 pnpm --filter @workspace/pwv-home run dev"
waitForPort = 22335

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "artifacts/pwv-colorado: web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BASE_PATH=/locations/ PORT=21781 pnpm --filter @workspace/pwv-colorado run dev"
waitForPort = 21781

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "artifacts/pwv-microsite: web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "BASE_PATH=/savings/ PORT=23223 pnpm --filter @workspace/pwv-microsite run dev"
waitForPort = 23223

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
